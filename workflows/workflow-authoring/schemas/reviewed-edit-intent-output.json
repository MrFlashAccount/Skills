{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Authoring Reviewed Edit Intent Output",
  "type": "object",
  "required": [
    "outcome"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "ready_for_implementation",
        "blocked"
      ]
    },
    "edit_intent": {
      "type": "object",
      "required": [
        "approval_boundary",
        "approved_findings",
        "allowed_edit_surfaces",
        "non_goals",
        "required_validation_evidence"
      ],
      "properties": {
        "approval_boundary": {
          "type": "string",
          "minLength": 1
        },
        "approved_findings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_edit_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_validation_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "blocker": {
      "type": "object",
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "needed": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "ready_for_implementation"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "edit_intent"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "blocked"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "blocker"
        ]
      }
    }
  ]
}
