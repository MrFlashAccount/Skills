{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "outcome"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "ready_for_attack",
        "blocked"
      ]
    },
    "workflow_contract": {
      "type": "object"
    },
    "blocker": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "ready_for_attack"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "workflow_contract"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "blocked"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "blocker"
        ]
      }
    }
  ]
}
