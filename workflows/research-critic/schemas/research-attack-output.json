{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/research-critic/research-attack-output",
  "title": "Research Attack Output",
  "description": "Neutral reusable output contract for researcher attack of a research draft.",
  "type": "object",
  "required": [
    "outcome"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "approved",
        "needs_revision",
        "needs_input",
        "blocked"
      ],
      "description": "Authoritative routing state for the researcher attack."
    },
    "verdict": {
      "type": "object",
      "required": [
        "summary",
        "evidence_checked",
        "findings"
      ],
      "properties": {
        "summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_checked": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    },
    "questions": {
      "type": "array",
      "description": "Blocking user questions when outcome is needs_input.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      }
    },
    "blocker": {
      "$ref": "#/$defs/blocker"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1
        },
        "needed": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "enum": [
              "approved",
              "needs_revision"
            ]
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "verdict"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "needs_input"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "questions"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "blocked"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "blocker"
        ]
      }
    }
  ]
}
