{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/research-critic/save-research-packet-output",
  "title": "Research Critic Save Research Packet Output",
  "description": "Neutral reusable output contract for final research packet persistence metadata.",
  "type": "object",
  "required": [
    "outcome"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "saved",
        "blocked"
      ],
      "description": "Authoritative routing state for final persistence."
    },
    "saved": {
      "type": "object",
      "required": [
        "summary",
        "artifact_path"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "history_note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "minItems": 1,
      "description": "Saved research packet artifact metadata using id, content_type, and <runDir>/<stepId>/artifacts/<artifactId>... path.",
      "x-usage": "Use artifact files as the source of truth for human-facing research content; structured JSON remains for workflow branching."
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      },
      "minItems": 1
    },
    "blocker": {
      "$ref": "#/$defs/blocker"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1
        },
        "needed": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": [
        "id",
        "content_type",
        "path"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Artifact id unique within the producer step.",
          "x-usage": "Use with the current producer step id to identify the artifact; do not treat it as globally unique by itself."
        },
        "content_type": {
          "type": "string",
          "minLength": 1,
          "description": "MIME/content type, for example text/markdown or application/json.",
          "x-usage": "Use this to decide how to read/render the file; do not duplicate it with artifact type/kind."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Run-relative path using <stepId>/artifacts/<artifactId>... layout.",
          "x-usage": "Treat as run-relative file location under the producer step artifacts directory."
        },
        "summary": {
          "type": "string"
        },
        "ref": {
          "type": "string",
          "description": "Optional derived locator; prefer path plus step-scoped id unless a consumer needs a compact display reference.",
          "x-usage": "Optional display locator only; derive it from step context/id/path when absent."
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "saved"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "saved",
          "artifacts",
          "results"
        ],
        "not": {
          "required": [
            "blocker"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "blocked"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "blocker"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "saved"
              ]
            },
            {
              "required": [
                "artifacts"
              ]
            },
            {
              "required": [
                "results"
              ]
            }
          ]
        }
      }
    }
  ]
}
