{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/research-critic/save-research-packet-output",
  "title": "Research Critic Save Research Packet Output",
  "description": "Neutral reusable output contract for final research packet persistence metadata.",
  "type": "object",
  "required": [
    "outcome"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "saved",
        "blocked"
      ],
      "description": "Authoritative routing state for final persistence."
    },
    "saved": {
      "type": "object",
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "history_note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact"
      },
      "minItems": 1,
      "description": "Saved research packet artifact metadata.",
      "x-usage": "Use artifact files as the source of truth for human-facing research content; structured JSON remains for workflow branching. Exact artifact field semantics come from the shared baton artifact schema."
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      },
      "minItems": 1
    },
    "blocker": {
      "$ref": "#/$defs/blocker"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1
        },
        "needed": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "saved"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "saved",
          "artifacts",
          "results"
        ],
        "not": {
          "required": [
            "blocker"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "blocked"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "blocker"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "saved"
              ]
            },
            {
              "required": [
                "artifacts"
              ]
            },
            {
              "required": [
                "results"
              ]
            }
          ]
        }
      }
    }
  ]
}
