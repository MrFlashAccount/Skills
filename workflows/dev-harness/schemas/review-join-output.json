{
  "title": "DevHarness Review Join Output",
  "description": "Producer output contract for joining DevHarness review branch verdicts and selecting the next loop target.",
  "type": "object",
  "required": [
    "outcome"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "passed",
        "needs_changes",
        "blocked"
      ],
      "description": "Producer must emit the single enum value that reflects the completed stage state; use blocked only when blocker explains the stop condition.",
      "x-usage": "Treat this as the authoritative workflow state for this output. Do not infer success from other populated fields when this says blocked or needs revision."
    },
    "verdict": {
      "type": "object",
      "required": [
        "summary",
        "selected_review_steps",
        "failed_review_steps"
      ],
      "properties": {
        "summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Producer must summarize the relevant decision or handoff in concise human-readable form without adding new scope.",
          "x-usage": "Use this as concise human-readable context only. Do not route, approve, or expand scope from this text."
        },
        "selected_review_steps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "architect_review",
              "backend_review",
              "frontend_review",
              "frontend_taste_review",
              "security_review",
              "privacy_review",
              "qa_review"
            ]
          },
          "description": "Producer must report the review branch ids represented in the join decision.",
          "x-usage": "Use this to verify which review steps are represented. Do not assume unlisted planned reviews passed."
        },
        "failed_review_steps": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "architect_review",
              "backend_review",
              "frontend_review",
              "frontend_taste_review",
              "security_review",
              "privacy_review",
              "qa_review"
            ]
          },
          "description": "Producer must list review branch ids that failed, requested changes, or could not complete.",
          "x-usage": "Use this to explain failures or incomplete checks. Do not derive rework targets from this field; use next or required_implementation_steps."
        },
        "required_implementation_steps": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "backend_implementation",
              "frontend_implementation",
              "architecture_artifact_update"
            ]
          },
          "description": "Producer must list implementation branch ids that must rerun to address joined review findings.",
          "x-usage": "Use only these implementation branch ids when next requests a rework loop. Do not widen rework from prose alone."
        }
      },
      "additionalProperties": true,
      "description": "Producer must aggregate review branch verdicts into one join decision with selected reviews, failures, and rework targets.",
      "x-usage": "Treat this plus next as the authoritative joined decision. Do not modify the approved plan except through the explicit next rework target."
    },
    "next": {
      "oneOf": [
        {
          "enum": [
            "done",
            "blocked"
          ]
        },
        {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "backend_implementation",
              "frontend_implementation",
              "architecture_artifact_update"
            ]
          }
        }
      ],
      "description": "Producer must set the next workflow target: done, blocked, or the implementation branch ids selected for rework.",
      "x-usage": "Execute this as the workflow loop target. done terminates, blocked stops, and arrays rerun only the listed implementation branches."
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact"
      },
      "description": "Producer may emit named structured artifacts created by this stage when they are part of the handoff.",
      "x-usage": "Use these only as supporting named artifacts to preserve or pass along. Do not treat them as routing decisions unless another field explicitly references them."
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      },
      "description": "Producer may emit compact structured results, decisions, or evidence summaries created by this stage.",
      "x-usage": "Use these as supporting evidence or compact summaries. Do not let them override outcome, selected steps, blockers, or approved contracts."
    },
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "Producer must summarize the relevant decision or handoff in concise human-readable form without adding new scope.",
          "x-usage": "Use this as concise human-readable context only. Do not route, approve, or expand scope from this text."
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1,
          "description": "Producer must name the workflow step id that found or owns this blocker or finding.",
          "x-usage": "Use this to identify the step that found or owns the blocker/finding. Do not treat it as a retry target by itself."
        },
        "needed": {
          "type": "string",
          "minLength": 1,
          "description": "Producer must state the exact missing decision, permission, input, or evidence required to proceed.",
          "x-usage": "Surface this exact missing input, permission, evidence, or decision before proceeding. Do not substitute assumptions for it."
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Producer should list concrete evidence references supporting this handoff, verdict, finding, or blocker.",
          "x-usage": "Use these references to inspect or challenge the claim. Do not assume unreferenced surfaces were checked."
        },
        "risk": {
          "type": "string",
          "description": "Producer should describe the residual risk if this blocker or finding is ignored.",
          "x-usage": "Use this to understand why ignoring the item is unsafe. Treat it as risk context unless paired with a blocked outcome."
        }
      },
      "additionalProperties": false,
      "description": "Producer must populate this when outcome is blocked, naming the stop reason, owning step, and specific missing input or permission.",
      "x-usage": "Treat this as a stop condition. Surface the missing input or decision instead of continuing or working around it."
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/dev-harness/review-join-output",
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "passed"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "verdict",
          "next"
        ],
        "properties": {
          "next": {
            "const": "done"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "needs_changes"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "verdict",
          "next"
        ],
        "properties": {
          "verdict": {
            "type": "object",
            "required": [
              "required_implementation_steps"
            ],
            "properties": {
              "required_implementation_steps": {
                "type": "array",
                "minItems": 1
              }
            }
          },
          "next": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        },
        "allOf": [
          {
            "if": {
              "required": [
                "verdict"
              ],
              "properties": {
                "verdict": {
                  "type": "object",
                  "required": [
                    "required_implementation_steps"
                  ],
                  "properties": {
                    "required_implementation_steps": {
                      "contains": {
                        "const": "backend_implementation"
                      },
                      "type": "array"
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "next": {
                  "contains": {
                    "const": "backend_implementation"
                  },
                  "type": "array"
                }
              }
            }
          },
          {
            "if": {
              "required": [
                "next"
              ],
              "properties": {
                "next": {
                  "contains": {
                    "const": "backend_implementation"
                  },
                  "type": "array"
                }
              }
            },
            "then": {
              "properties": {
                "verdict": {
                  "type": "object",
                  "properties": {
                    "required_implementation_steps": {
                      "contains": {
                        "const": "backend_implementation"
                      },
                      "type": "array"
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "required": [
                "verdict"
              ],
              "properties": {
                "verdict": {
                  "type": "object",
                  "required": [
                    "required_implementation_steps"
                  ],
                  "properties": {
                    "required_implementation_steps": {
                      "contains": {
                        "const": "frontend_implementation"
                      },
                      "type": "array"
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "next": {
                  "contains": {
                    "const": "frontend_implementation"
                  },
                  "type": "array"
                }
              }
            }
          },
          {
            "if": {
              "required": [
                "next"
              ],
              "properties": {
                "next": {
                  "contains": {
                    "const": "frontend_implementation"
                  },
                  "type": "array"
                }
              }
            },
            "then": {
              "properties": {
                "verdict": {
                  "type": "object",
                  "properties": {
                    "required_implementation_steps": {
                      "contains": {
                        "const": "frontend_implementation"
                      },
                      "type": "array"
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "required": [
                "verdict"
              ],
              "properties": {
                "verdict": {
                  "type": "object",
                  "required": [
                    "required_implementation_steps"
                  ],
                  "properties": {
                    "required_implementation_steps": {
                      "contains": {
                        "const": "architecture_artifact_update"
                      },
                      "type": "array"
                    }
                  }
                }
              }
            },
            "then": {
              "properties": {
                "next": {
                  "contains": {
                    "const": "architecture_artifact_update"
                  },
                  "type": "array"
                }
              }
            }
          },
          {
            "if": {
              "required": [
                "next"
              ],
              "properties": {
                "next": {
                  "contains": {
                    "const": "architecture_artifact_update"
                  },
                  "type": "array"
                }
              }
            },
            "then": {
              "properties": {
                "verdict": {
                  "type": "object",
                  "properties": {
                    "required_implementation_steps": {
                      "contains": {
                        "const": "architecture_artifact_update"
                      },
                      "type": "array"
                    }
                  }
                }
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "blocked"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "blocker",
          "next"
        ],
        "properties": {
          "next": {
            "const": "blocked"
          }
        }
      }
    }
  ]
}
