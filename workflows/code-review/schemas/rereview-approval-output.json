{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/code-review/rereview-approval-output",
  "title": "Code Review Re-review Approval Output",
  "description": "Human decision for running another code-review pass after a needs_changes verdict.",
  "type": "object",
  "required": [
    "approval"
  ],
  "properties": {
    "approval": {
      "enum": [
        "approved",
        "rejected",
        "blocked"
      ]
    },
    "remarks": {
      "type": "string"
    },
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_step_id": {
          "const": "rereview_gate"
        },
        "needed": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "approval": {
            "const": "blocked"
          }
        },
        "required": [
          "approval"
        ]
      },
      "then": {
        "required": [
          "blocker"
        ]
      }
    }
  ]
}
