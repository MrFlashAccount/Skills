{
  "workflow": {
    "name": "dev-harness",
    "version": 1,
    "start": "research",
    "done": "done",
    "blocked": "blocked",
    "steps": {
      "research": {
        "name": "Research",
        "kind": "worker",
        "input": {
          "template": "templates/dev-harness/research.md",
          "role": "researcher",
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Read task context, classify the slice, gather relevant local/project evidence, identify constraints, risks, open questions, and whether architecture-sensitive scope exists. Produce a compact research packet for critic review."
        },
        "output": {
          "template": "../../shared/templates/research-packet-template.md"
        },
        "next": {
          "by": "outcome",
          "map": {
            "ready_for_critic": "research_critic",
            "blocked": "blocked"
          }
        }
      },
      "research_critic": {
        "name": "Research critic",
        "kind": "worker",
        "input": {
          "template": "templates/dev-harness/research-critic.md",
          "role": "reviewer",
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Attack the research packet for missing evidence, unsafe assumptions, scope drift, sensitive surfaces, and unclear approval questions. Allow one bounded revision loop when gaps are fixable."
        },
        "output": {
          "template": "../../shared/templates/review-verdict-template.md"
        },
        "next": {
          "by": "outcome",
          "map": {
            "approved": "approve_research",
            "needs_revision": {
              "target": "research",
              "maxAttempts": 3,
              "onLimit": "blocked"
            },
            "blocked": "blocked"
          }
        }
      },
      "approve_research": {
        "name": "Approve research",
        "kind": "approval",
        "input": {
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Show the cleaned research review packet to the user. Continue only after explicit approval."
        },
        "next": {
          "by": "approval",
          "map": {
            "approved": "architecture",
            "rejected": "research",
            "blocked": "blocked"
          }
        }
      },
      "architecture": {
        "name": "Architecture gate",
        "kind": "worker",
        "input": {
          "template": "templates/dev-harness/architecture.md",
          "role": "architect",
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Decide whether the approved research requires an architecture-sensitive structural contract or durable architecture artifact work. For architecture-sensitive work, produce the minimal structural contract; otherwise record an explicit no-architecture-artifact decision."
        },
        "output": {
          "template": "../../shared/templates/architecture-proposal-template.md"
        },
        "next": {
          "by": "outcome",
          "map": {
            "ready_for_review": "architect_review",
            "skip_review": "approve_architecture",
            "blocked": "blocked"
          }
        }
      },
      "architect_review": {
        "name": "Architect review",
        "kind": "worker",
        "input": {
          "template": "templates/dev-harness/architect-review.md",
          "role": "architect",
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Attack the architecture decision or structural contract for ownership seams, dependency direction, contract surfaces, and durable artifact pressure. Allow one bounded revise/re-review loop when fixable."
        },
        "output": {
          "template": "../../shared/templates/review-verdict-template.md"
        },
        "next": {
          "by": "outcome",
          "map": {
            "approved": "approve_architecture",
            "needs_revision": {
              "target": "architecture",
              "maxAttempts": 3,
              "onLimit": "blocked"
            },
            "blocked": "blocked"
          }
        }
      },
      "approve_architecture": {
        "name": "Approve architecture",
        "kind": "approval",
        "input": {
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Show the architecture decision or structural contract to the user. Continue only after explicit approval when the slice is non-trivial or architecture-sensitive."
        },
        "next": {
          "by": "approval",
          "map": {
            "approved": "implementation_plan",
            "rejected": "architecture",
            "blocked": "blocked"
          }
        }
      },
      "implementation_plan": {
        "name": "Implementation plan",
        "kind": "worker",
        "input": {
          "template": "templates/dev-harness/implementation-plan.md",
          "role": "architect",
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Translate approved research and any structural contract into an execution contract: file zones, implementer owners, entities, verification surfaces, rollback surfaces, docs/contract touchpoints, risks, assumptions, and handoff inputs."
        },
        "output": {
          "template": "../../shared/templates/implementation-plan-template.md"
        },
        "next": {
          "by": "outcome",
          "map": {
            "ready_for_review": "plan_review",
            "blocked": "blocked"
          }
        }
      },
      "plan_review": {
        "name": "Plan review",
        "kind": "worker",
        "input": {
          "template": "templates/dev-harness/plan-review.md",
          "role": "reviewer",
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Challenge the execution plan for entity coverage, one-owner-per-file-zone, project baseline, architecture artifact manifest, verification and rollback surfaces, sensitive surfaces, request-path/contract touchpoints, and max-detail leaks."
        },
        "output": {
          "template": "../../shared/templates/review-verdict-template.md"
        },
        "next": {
          "by": "outcome",
          "map": {
            "approved": "approve_plan",
            "needs_revision": {
              "target": "implementation_plan",
              "maxAttempts": 3,
              "onLimit": "blocked"
            },
            "blocked": "blocked"
          }
        }
      },
      "approve_plan": {
        "name": "Approve implementation plan",
        "kind": "approval",
        "input": {
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Show one cleaned execution plan to the user. Stop until explicit implementation approval."
        },
        "next": {
          "by": "approval",
          "map": {
            "approved": "implementation_handoff",
            "rejected": {
              "target": "implementation_plan",
              "maxAttempts": 3,
              "onLimit": "blocked"
            },
            "blocked": "blocked"
          }
        }
      },
      "implementation_handoff": {
        "name": "Implementation handoff",
        "kind": "worker",
        "input": {
          "template": "templates/dev-harness/implementation-handoff.md",
          "role": "backend",
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Build the handoff packet for implementation-harness from approved task context, approved research, structural contract when present, approved execution plan, supporting materials, and user constraints. Route concrete coding through delegated implementer roles rather than the orchestrator."
        },
        "output": {
          "template": "../../shared/templates/implementer-handoff-template.md"
        },
        "next": {
          "by": "outcome",
          "map": {
            "ready_for_review": "review",
            "blocked": "blocked"
          }
        }
      },
      "review": {
        "name": "Post-implementation review",
        "kind": "worker",
        "input": {
          "template": "templates/dev-harness/review.md",
          "role": "reviewer",
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Run the explicit post-implementation review gate, including verification evidence, contract/docs drift, sensitive-surface handling, and scope-growth or redesign pressure. Return for implementation fixes when needed."
        },
        "output": {
          "template": "../../shared/templates/review-verdict-template.md"
        },
        "next": {
          "by": "outcome",
          "map": {
            "passed": "done",
            "needs_changes": {
              "target": "implementation_handoff",
              "maxAttempts": 3,
              "onLimit": "blocked"
            },
            "blocked": "blocked"
          }
        }
      },
      "done": {
        "name": "Done",
        "kind": "done",
        "input": {
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Workflow completed; return final summary and durable follow-up notes when applicable."
        }
      },
      "blocked": {
        "name": "Blocked",
        "kind": "blocked",
        "input": {
          "state": [
            "artifacts",
            "results"
          ],
          "prompt": "Workflow blocked; return the blocker, evidence, risk, and exact next decision or missing input."
        }
      }
    }
  }
}
