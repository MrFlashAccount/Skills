{
  "workflow": {
    "name": "dev-harness",
    "version": 1,
    "start": "research",
    "done": "done",
    "blocked": "blocked",
    "steps": {
      "research": {
        "kind": "subagent",
        "template": "dev_harness.research",
        "outcomes": {
          "ready_for_approval": "approve_research",
          "blocked": "blocked"
        },
        "producesArtifacts": [
          "research"
        ]
      },
      "approve_research": {
        "kind": "user_approval",
        "outcomes": {
          "approved": "architecture",
          "rejected": "research",
          "blocked": "blocked"
        },
        "takesArtifacts": [
          "research"
        ],
        "producesArtifacts": [
          "research_approval"
        ]
      },
      "architecture": {
        "kind": "subagent",
        "template": "dev_harness.architecture",
        "outcomes": {
          "ready_for_approval": "approve_architecture",
          "blocked": "blocked"
        },
        "takesArtifacts": [
          "research"
        ],
        "producesArtifacts": [
          "architecture"
        ]
      },
      "approve_architecture": {
        "kind": "user_approval",
        "outcomes": {
          "approved": "implementation_plan",
          "rejected": "architecture",
          "blocked": "blocked"
        },
        "takesArtifacts": [
          "architecture"
        ],
        "producesArtifacts": [
          "architecture_approval"
        ]
      },
      "implementation_plan": {
        "kind": "subagent",
        "template": "dev_harness.implementation_plan",
        "outcomes": {
          "ready_for_approval": "approve_plan",
          "blocked": "blocked"
        },
        "takesArtifacts": [
          "research",
          "architecture"
        ],
        "producesArtifacts": [
          "implementationPlan"
        ]
      },
      "approve_plan": {
        "kind": "user_approval",
        "outcomes": {
          "approved": "implementation",
          "rejected": "implementation_plan",
          "blocked": "blocked"
        },
        "takesArtifacts": [
          "implementationPlan"
        ],
        "producesArtifacts": [
          "implementationPlan_approval"
        ]
      },
      "implementation": {
        "kind": "subagent",
        "template": "dev_harness.implementation",
        "outcomes": {
          "ready_for_review": "review",
          "blocked": "blocked"
        },
        "takesArtifacts": [
          "research",
          "architecture",
          "implementationPlan"
        ],
        "producesArtifacts": [
          "implementation"
        ]
      },
      "review": {
        "kind": "subagent",
        "template": "dev_harness.review",
        "outcomes": {
          "passed": "done",
          "needs_changes": "implementation",
          "blocked": "blocked"
        },
        "takesArtifacts": [
          "implementation"
        ],
        "producesArtifacts": [
          "review"
        ]
      },
      "done": {
        "kind": "terminal",
        "producesArtifacts": [
          "final_summary"
        ]
      },
      "blocked": {
        "kind": "terminal",
        "producesArtifacts": [
          "blocker_summary"
        ]
      }
    }
  },
  "prompt_generation": {
    "template_id": "dev_harness.worker_prompt",
    "inputs": [
      "task",
      "cursor",
      "cursor_instructions",
      "approved_artifacts",
      "constraints",
      "expected_output_format"
    ],
    "exclusions": [
      "workflow_graph",
      "baton",
      "global_node",
      "allowed_handoffs"
    ]
  },
  "handoff_helper": {
    "modes": {
      "inspect": {
        "input": [
          "workflow",
          "baton"
        ],
        "validates": [
          "workflow_shape",
          "baton_shape",
          "cursor_exists",
          "required_artifacts_present_for_cursor"
        ],
        "output": [
          "baton",
          "directive"
        ],
        "mutates_baton": false
      },
      "apply": {
        "input": [
          "workflow",
          "baton",
          "worker_or_approval_output"
        ],
        "validates": [
          "workflow_shape",
          "baton_shape",
          "output_shape_for_cursor",
          "handoff_outcome_exists_in_workflow",
          "handoff_allowed_from_cursor",
          "required_output_artifacts_present"
        ],
        "output": [
          "baton",
          "directive"
        ]
      }
    }
  }
}
