{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/runs-index",
  "title": "Workflow Runs Index",
  "description": "Persistent develop/.workflow-runs/runs.json contract. Entries expose only the public runId and safe run metadata; private run directories/roots and raw prompts are not part of this shape.",
  "type": "object",
  "required": ["schemaVersion", "topologyVersion", "runs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "topologyVersion": { "const": "workflow-runs-v1" },
    "runs": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/runId" },
      "additionalProperties": { "$ref": "#/$defs/runIndexEntry" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "runId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "safeTextMetadata": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:@/-]{0,255}$"
    },
    "safeFailureMetadata": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "anyOf": [
        { "const": "[redacted]" },
        { "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,255}$" }
      ]
    },
    "runIndexEntry": {
      "type": "object",
      "required": ["runId", "workflow", "status", "createdAt", "updatedAt", "workerLease"],
      "properties": {
        "runId": { "$ref": "#/$defs/runId" },
        "summary": { "type": "string" },
        "title": { "type": "string" },
        "workflow": {
          "type": "object",
          "required": ["path"],
          "properties": {
            "identity": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "status": { "enum": ["running", "needs_host_actions", "done", "blocked", "failed"] },
        "createdAt": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "minLength": 1 },
        "taskKey": { "$ref": "#/$defs/safeTextMetadata" },
        "taskFingerprint": { "$ref": "#/$defs/safeTextMetadata" },
        "failure": {
          "type": "object",
          "required": ["request_id", "error_code", "failure_code"],
          "properties": {
            "request_id": { "$ref": "#/$defs/safeFailureMetadata" },
            "error_code": { "$ref": "#/$defs/safeFailureMetadata" },
            "failure_code": { "$ref": "#/$defs/safeFailureMetadata" },
            "workflow_run_id": { "$ref": "#/$defs/safeFailureMetadata" },
            "failed_step_id": { "$ref": "#/$defs/safeFailureMetadata" },
            "failed_session_key": { "$ref": "#/$defs/safeFailureMetadata" },
            "runtime_run_id": { "$ref": "#/$defs/safeFailureMetadata" }
          },
          "additionalProperties": false
        },
        "workerLease": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["tokenHash", "tokenEpoch", "leaseExpiresAt"],
              "properties": {
                "tokenHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                "tokenEpoch": { "type": "integer", "minimum": 1 },
                "leaseExpiresAt": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
