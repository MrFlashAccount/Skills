{
  "name": "fixture-parallel-mixed",
  "version": 1,
  "start": "prepare",
  "done": "done",
  "blocked": "blocked",
  "steps": {
    "prepare": {
      "name": "Prepare",
      "kind": "worker",
      "input": { "prompt": "Prepare branch inputs." },
      "output": { "template": "output.md" },
      "next": ["lint", { "match": "${{ output.outcome }}", "cases": { "ready": "build", "blocked": "blocked" } }]
    },
    "lint": {
      "name": "Lint",
      "kind": "worker",
      "input": { "state": ["prepare"], "prompt": "Run lint branch." },
      "output": { "template": "output.md" },
      "next": "join"
    },
    "build": {
      "name": "Build",
      "kind": "worker",
      "input": { "state": ["prepare"], "prompt": "Run build branch." },
      "output": { "template": "output.md" },
      "next": "join"
    },
    "join": {
      "name": "Join",
      "kind": "worker",
      "input": { "state": ["lint", "build"], "prompt": "Synthesize branch outputs." },
      "output": { "template": "output.md" },
      "next": "done"
    },
    "done": { "name": "Done", "kind": "done", "input": { "prompt": "Finished." } },
    "blocked": { "name": "Blocked", "kind": "blocked", "input": { "prompt": "Blocked." } }
  }
}
