{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["outcome", "results"],
  "properties": {
    "outcome": { "enum": ["ready", "retry", "blocked"] },
    "blocker": { "type": "object" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "summary"],
        "properties": {
          "type": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
