{
  "name": "fixture-approval-first-fanout",
  "version": 1,
  "start": "intake_approval",
  "done": "done",
  "blocked": "blocked",
  "steps": {
    "intake_approval": {
      "name": "Intake Approval",
      "kind": "approval",
      "input": { "prompt": "Accept the startup request before worker execution." },
      "next": "prepare"
    },
    "prepare": {
      "name": "Prepare",
      "kind": "worker",
      "input": { "state": ["intake_approval"], "prompt": "Prepare approved startup request." },
      "output": { "template": "output.md" },
      "next": ["branch_a", "branch_b"]
    },
    "branch_a": {
      "name": "Branch A",
      "kind": "worker",
      "input": { "state": ["prepare"], "prompt": "Do branch A." },
      "output": { "template": "output.md" },
      "next": "join"
    },
    "branch_b": {
      "name": "Branch B",
      "kind": "worker",
      "input": { "state": ["prepare"], "prompt": "Do branch B." },
      "output": { "template": "output.md" },
      "next": "join"
    },
    "join": {
      "name": "Join",
      "kind": "worker",
      "input": { "state": ["branch_a", "branch_b"], "prompt": "Join branch results." },
      "output": { "template": "output.md" },
      "next": "final_approval"
    },
    "final_approval": {
      "name": "Final Approval",
      "kind": "approval",
      "input": { "state": ["join"], "prompt": "Approve final result." },
      "next": { "match": "${{ output.approval }}", "cases": { "approved": "done", "blocked": "blocked" } }
    },
    "done": { "name": "Done", "kind": "done", "input": { "prompt": "Finished." } },
    "blocked": { "name": "Blocked", "kind": "blocked", "input": { "prompt": "Blocked." } }
  }
}
