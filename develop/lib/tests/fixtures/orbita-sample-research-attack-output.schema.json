{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/orbita-sample/research-attack-output",
  "title": "Orbita Sample Research Attack Output",
  "type": "object",
  "required": [
    "outcome"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "approved",
        "needs_revision",
        "blocked"
      ]
    },
    "verdict": {
      "type": "object",
      "required": [
        "summary",
        "evidence_checked",
        "findings"
      ],
      "properties": {
        "summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_checked": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "findings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "category",
              "severity",
              "summary",
              "description",
              "evidence"
            ],
            "properties": {
              "category": {
                "enum": [
                  "must",
                  "should",
                  "can",
                  "delay"
                ]
              },
              "severity": {
                "enum": [
                  "must",
                  "should",
                  "can",
                  "delay"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "ref",
                    "details"
                  ],
                  "properties": {
                    "ref": {
                      "type": "string",
                      "minLength": 1
                    },
                    "details": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "recommendation": {
                "type": "string",
                "minLength": 1
              },
              "required_change": {
                "type": "string",
                "minLength": 1
              }
            },
            "anyOf": [
              {
                "required": [
                  "recommendation"
                ]
              },
              {
                "required": [
                  "required_change"
                ]
              }
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      }
    },
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1
        },
        "needed": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "enum": [
              "approved",
              "needs_revision"
            ]
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "verdict"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "blocked"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "required": [
          "blocker"
        ]
      }
    }
  ]
}
