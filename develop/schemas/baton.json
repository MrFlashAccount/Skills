{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/dev-harness/schemas/baton",
  "title": "DevHarness Baton",
  "type": "object",
  "required": ["cursor", "state"],
  "properties": {
    "cursor": { "type": "string" },
    "status": { "type": "string" },
    "state": {
      "type": "object",
      "required": ["artifacts"],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact" }
        }
      },
      "additionalProperties": true
    },
    "lastHandoff": { "type": "string" },
    "blocker": { "type": "object" }
  },
  "additionalProperties": true,
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "ref": { "type": "string" },
        "summary": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
