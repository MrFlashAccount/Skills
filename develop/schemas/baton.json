{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton",
  "title": "Workflow Baton",
  "type": "object",
  "required": [
    "cursor",
    "status",
    "state"
  ],
  "properties": {
    "cursor": {
      "type": "string"
    },
    "status": {
      "enum": [
        "running",
        "done",
        "blocked"
      ]
    },
    "state": {
      "type": "object",
      "required": [
        "artifacts",
        "results"
      ],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/result"
          }
        },
        "attempts": {
          "description": "Interpreter-owned retry counters keyed by workflow edge.",
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "outputs": {
          "description": "Legacy mirror of validated structured per-step worker outputs keyed by step id.",
          "type": "object",
          "additionalProperties": true
        }
      },
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_-]*$": {
          "description": "Per-step worker output keyed by workflow step id for downstream input.state projection."
        }
      },
      "propertyNames": {
        "not": { "enum": ["run", "history"] }
      },
      "additionalProperties": false
    },
    "parallel": {
      "description": "Interpreter-owned pending parallel branch state.",
      "type": "object",
      "required": ["from", "targets", "join"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "join": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "blocker": {
      "type": "object"
    },
    "error": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "result": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "cursor": {
          "type": "string"
        },
        "outcome": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
