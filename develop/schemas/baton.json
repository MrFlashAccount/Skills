{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/dev-harness/schemas/baton",
  "title": "DevHarness Baton",
  "type": "object",
  "required": ["cursor", "state"],
  "properties": {
    "cursor": { "type": "string" },
    "status": { "enum": ["running", "done", "blocked"] },
    "state": {
      "type": "object",
      "required": ["artifacts"],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact" }
        },
        "results": {
          "type": "array",
          "items": { "$ref": "#/$defs/result" }
        },
        "history": {
          "type": "array",
          "items": { "$ref": "#/$defs/historyEvent" }
        },
        "attempts": { "$ref": "#/$defs/attempts" }
      },
      "additionalProperties": true
    },
    "lastHandoff": { "type": "string" },
    "blocker": { "type": "object" },
    "error": { "type": "object" }
  },
  "additionalProperties": true,
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "ref": { "type": "string" },
        "summary": { "type": "string" }
      },
      "additionalProperties": true
    },
    "result": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "cursor": { "type": "string" },
        "outcome": { "type": "string" },
        "summary": { "type": "string" },
        "ref": { "type": "string" }
      },
      "additionalProperties": true
    },
    "historyEvent": {
      "type": "object",
      "required": ["event", "cursor", "target", "handoff", "at"],
      "properties": {
        "event": { "type": "string" },
        "cursor": { "type": "string" },
        "target": { "type": "string" },
        "handoff": { "type": "string" },
        "status": { "enum": ["running", "done", "blocked"] },
        "at": { "type": "string" }
      },
      "additionalProperties": true
    },
    "attempts": {
      "type": "object",
      "propertyNames": { "type": "string" },
      "additionalProperties": {
        "oneOf": [
          { "type": "integer", "minimum": 0 },
          {
            "type": "object",
            "properties": {
              "count": { "type": "integer", "minimum": 0 },
              "lastError": { "type": "string" },
              "lastAt": { "type": "string" }
            },
            "additionalProperties": true
          }
        ]
      }
    }
  }
}
