{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton",
  "title": "Workflow Baton",
  "type": "object",
  "required": [
    "cursor",
    "status",
    "state"
  ],
  "properties": {
    "cursor": {
      "type": "string"
    },
    "status": {
      "enum": [
        "running",
        "done",
        "blocked"
      ]
    },
    "state": {
      "type": "object",
      "required": [
        "artifacts",
        "results"
      ],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/result"
          }
        },
        "attempts": {
          "description": "Interpreter-owned retry counters keyed by workflow edge.",
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "outputs": {
          "description": "Legacy mirror of validated structured per-step worker outputs keyed by step id.",
          "type": "object",
          "additionalProperties": true
        }
      },
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_-]*$": {
          "description": "Per-step worker output keyed by workflow step id for downstream input.state projection."
        }
      },
      "propertyNames": {
        "not": {
          "enum": [
            "run",
            "history"
          ]
        }
      },
      "additionalProperties": false
    },
    "user_prompt": {
      "description": "Raw run-level startup user prompt captured when the workflow run is initialized. Immutable after start/resume.",
      "type": "string",
      "allOf": [
        {
          "pattern": "\\S"
        }
      ]
    },
    "blocker": {
      "type": "object"
    },
    "error": {
      "type": "object"
    },
    "user_prompt_injected": {
      "description": "Interpreter/runner marker set after the selected startup-prompt worker output has been applied. Prevents reinjection after completion/resume or workflow drift while allowing repeated renders of the same uncompleted worker to preserve the prompt.",
      "type": "boolean"
    },
    "user_prompt_target": {
      "description": "Interpreter-owned selected startup worker step id that receives baton.user_prompt before any worker output exists. Stable across resume and workflow order drift.",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "artifact": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "result": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "cursor": {
          "type": "string"
        },
        "outcome": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
