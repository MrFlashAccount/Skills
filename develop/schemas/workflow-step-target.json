{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/dev-harness/schemas/workflow-step-target",
  "title": "DevHarness Target Workflow Step",
  "description": "Target workflow step shape only; captured for future design work and not wired into the current runtime.",
  "type": "object",
  "required": ["name", "kind"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["worker", "approval", "done"] },
    "input": { "$ref": "#/$defs/input" },
    "output": { "$ref": "#/$defs/output" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "kind": { "const": "worker" } },
        "required": ["kind"]
      },
      "then": true,
      "else": { "not": { "required": ["output"] } }
    }
  ],
  "$defs": {
    "input": {
      "type": "object",
      "properties": {
        "template": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string" },
        "state": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "required": ["schema"],
      "properties": {
        "schema": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
