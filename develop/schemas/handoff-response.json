{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/dev-harness/schemas/handoff-response",
  "title": "DevHarness Handoff Response",
  "type": "object",
  "required": ["baton", "directive"],
  "properties": {
    "baton": { "$ref": "https://openclaw.local/dev-harness/schemas/baton" },
    "directive": {
      "type": "object",
      "required": ["id", "kind", "template", "takesArtifacts", "producesArtifacts", "action"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": ["string", "null"] },
        "template": { "type": ["string", "null"] },
        "takesArtifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "producesArtifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "action": {
          "enum": ["run_worker", "wait_for_approval", "stop_done", "stop_blocked"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
