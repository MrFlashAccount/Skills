{
  "title": "DevHarness Research Draft Output",
  "type": "object",
  "required": [
    "outcome",
    "research_packet"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "ready_for_attack",
        "blocked"
      ]
    },
    "research_packet": {
      "type": "object",
      "required": [
        "summary",
        "scope",
        "constraints",
        "risks",
        "open_questions",
        "recommendation"
      ],
      "properties": {
        "summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scope": {
          "type": "object"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      }
    },
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1
        },
        "needed": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/dev-harness/research-draft-output"
}
