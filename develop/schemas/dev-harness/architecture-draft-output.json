{
  "title": "DevHarness Architecture Draft Output",
  "type": "object",
  "required": [
    "outcome",
    "architecture_contract"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "ready_for_attack",
        "blocked"
      ]
    },
    "architecture_contract": {
      "type": "object",
      "required": [
        "decision",
        "entities",
        "boundaries",
        "non_goals"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "entities": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "boundaries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      }
    },
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1
        },
        "needed": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/dev-harness/architecture-draft-output"
}
