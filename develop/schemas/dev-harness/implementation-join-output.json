{
  "title": "DevHarness Implementation Join Output",
  "type": "object",
  "required": [
    "outcome",
    "reviewer_handoff"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "ready_for_review",
        "blocked"
      ]
    },
    "reviewer_handoff": {
      "type": "object",
      "required": [
        "summary",
        "selected_implementation_steps",
        "selected_review_steps",
        "evidence"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "selected_implementation_steps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "backend_implementation",
              "frontend_implementation",
              "architecture_artifact_update"
            ]
          }
        },
        "selected_review_steps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "architect_review",
              "backend_review",
              "frontend_review",
              "frontend_taste_review",
              "security_review",
              "privacy_review",
              "qa_review"
            ]
          },
          "description": "Must be copied from the approved plan contract planning_draft.selected_review_steps; implementation_join does not choose reviewers."
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      }
    },
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1
        },
        "needed": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/dev-harness/implementation-join-output"
}
