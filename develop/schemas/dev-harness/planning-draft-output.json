{
  "title": "DevHarness Planning Draft Output",
  "description": "Output contract for the DevHarness planning draft that selects implementation and review routes.",
  "type": "object",
  "required": [
    "outcome",
    "implementation_plan",
    "selected_implementation_steps",
    "implementation_route",
    "selected_review_steps",
    "review_plan"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "ready_for_attack",
        "blocked"
      ],
      "description": "Machine-readable stage outcome used by workflow routing.",
      "x-usage": "Downstream next/match logic reads this value; choose only the enum/const value that matches the stage state."
    },
    "implementation_plan": {
      "type": "object",
      "required": [
        "goal",
        "workstreams",
        "definition_of_done",
        "verification",
        "rollback"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1,
          "description": "Single goal statement for the implementation slice.",
          "x-usage": "Keep aligned with the approved research and architecture contracts."
        },
        "workstreams": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          },
          "description": "Planner-level workstreams or implementation entities to execute.",
          "x-usage": "Use to split work by backend, frontend, and architecture artifact ownership without patch-level instructions."
        },
        "definition_of_done": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Acceptance criteria that must be true before implementation can join.",
          "x-usage": "Reviewers use this to decide whether the implementation satisfied the plan."
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Required verification commands, checks, or evidence for the slice.",
          "x-usage": "Implementation and review steps should report these exact checks or explain blockers."
        },
        "rollback": {
          "type": "string",
          "minLength": 1,
          "description": "Rollback or revert strategy for the implementation slice.",
          "x-usage": "Use to make recovery explicit before work is merged."
        }
      },
      "additionalProperties": true,
      "description": "Planner-owned implementation contract for the approved scope.",
      "x-usage": "Implementation workers use this as the source of truth for workstreams, done criteria, verification, and rollback."
    },
    "selected_implementation_steps": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "backend_implementation",
          "frontend_implementation",
          "architecture_artifact_update"
        ]
      },
      "description": "Concrete implementation branch step ids selected for this run.",
      "x-usage": "Implementation dispatch reads this list to fan out only the approved implementation branches."
    },
    "selected_review_steps": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "architect_review",
          "backend_review",
          "frontend_review",
          "frontend_taste_review",
          "security_review",
          "privacy_review",
          "qa_review"
        ]
      },
      "description": "Concrete review branch step ids selected by the planning contract.",
      "x-usage": "Implementation join and review dispatch copy this list to fan out only the planned review branches."
    },
    "review_plan": {
      "type": "object",
      "required": [
        "reviewers"
      ],
      "properties": {
        "reviewers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "step_id",
              "reason",
              "surfaces",
              "required"
            ],
            "properties": {
              "step_id": {
                "enum": [
                  "architect_review",
                  "backend_review",
                  "frontend_review",
                  "frontend_taste_review",
                  "security_review",
                  "privacy_review",
                  "qa_review"
                ],
                "description": "Workflow review step id.",
                "x-usage": "Must match one of selected_review_steps when this is a reviewer entry."
              },
              "reason": {
                "type": "string",
                "minLength": 1,
                "description": "Reason this reviewer or step is needed."
              },
              "surfaces": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "description": "Code, contract, docs, data, or UX surfaces this reviewer must inspect."
              },
              "required": {
                "type": "boolean",
                "description": "Whether this reviewer is mandatory for completion."
              }
            },
            "additionalProperties": false
          },
          "uniqueItems": true,
          "allOf": [
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "architect_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "backend_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "frontend_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "frontend_taste_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "security_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "privacy_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "qa_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            }
          ],
          "description": "Reviewer selections with reason, surfaces, and required flag.",
          "x-usage": "Keep one entry per selected review step so runtime and humans can audit why each reviewer runs."
        }
      },
      "additionalProperties": false,
      "description": "Planner-owned review contract describing required reviewers and surfaces.",
      "x-usage": "Review dispatch uses this to fan out review work; reviewers use it to understand their required scope."
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact"
      },
      "description": "Optional structured artifacts emitted by this stage.",
      "x-usage": "Use for named files or durable handoff artifacts the orchestrator should preserve."
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      },
      "description": "Optional structured result summaries emitted by this stage.",
      "x-usage": "Use for compact machine-readable evidence or decisions that should remain in baton state."
    },
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "Concise human-readable summary for this contract section."
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1,
          "description": "Workflow step id that discovered or owns the blocker."
        },
        "needed": {
          "type": "string",
          "minLength": 1,
          "description": "Specific missing input, decision, permission, or evidence needed to proceed."
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Evidence references supporting the handoff, verdict, or blocker."
        },
        "risk": {
          "type": "string",
          "description": "Residual risk if the blocker or finding is ignored."
        }
      },
      "additionalProperties": false,
      "description": "Blocker details required when the stage cannot produce a usable contract.",
      "x-usage": "Populate when outcome is blocked so the orchestrator can stop and ask for the missing input or decision."
    },
    "implementation_route": {
      "enum": [
        "backend",
        "frontend",
        "architecture",
        "backend_frontend",
        "backend_architecture",
        "frontend_architecture",
        "all"
      ],
      "description": "Compact route label that corresponds to selected implementation branches.",
      "x-usage": "Workflow semantic checks and dispatch use this value to fan out the correct implementation steps."
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/dev-harness/planning-draft-output",
  "allOf": [
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "backend"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "backend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "frontend"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "frontend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "architecture"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "architecture_artifact_update"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "backend_frontend"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "backend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "frontend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "backend_architecture"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "backend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "architecture_artifact_update"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "frontend_architecture"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "frontend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "architecture_artifact_update"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "all"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "backend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "frontend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "architecture_artifact_update"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    }
  ]
}
