{
  "title": "DevHarness Planning Draft Output",
  "type": "object",
  "required": [
    "outcome",
    "implementation_plan",
    "selected_implementation_steps",
    "implementation_route",
    "selected_review_steps",
    "review_plan"
  ],
  "properties": {
    "outcome": {
      "enum": [
        "ready_for_attack",
        "blocked"
      ]
    },
    "implementation_plan": {
      "type": "object",
      "required": [
        "goal",
        "workstreams",
        "definition_of_done",
        "verification",
        "rollback"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "workstreams": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          }
        },
        "definition_of_done": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "selected_implementation_steps": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "backend_implementation",
          "frontend_implementation",
          "architecture_artifact_update"
        ]
      }
    },
    "selected_review_steps": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "architect_review",
          "backend_review",
          "frontend_review",
          "frontend_taste_review",
          "security_review",
          "privacy_review",
          "qa_review"
        ]
      }
    },
    "review_plan": {
      "type": "object",
      "required": [
        "reviewers"
      ],
      "properties": {
        "reviewers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "step_id",
              "reason",
              "surfaces",
              "required"
            ],
            "properties": {
              "step_id": {
                "enum": [
                  "architect_review",
                  "backend_review",
                  "frontend_review",
                  "frontend_taste_review",
                  "security_review",
                  "privacy_review",
                  "qa_review"
                ]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "surfaces": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "uniqueItems": true,
          "allOf": [
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "architect_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "backend_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "frontend_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "frontend_taste_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "security_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "privacy_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "step_id": {
                    "const": "qa_review"
                  }
                },
                "required": [
                  "step_id"
                ]
              },
              "maxContains": 1
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/result"
      }
    },
    "blocker": {
      "type": "object",
      "required": [
        "summary",
        "source_step_id",
        "needed"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_step_id": {
          "type": "string",
          "minLength": 1
        },
        "needed": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "implementation_route": {
      "enum": [
        "backend",
        "frontend",
        "architecture",
        "backend_frontend",
        "backend_architecture",
        "frontend_architecture",
        "all"
      ]
    }
  },
  "additionalProperties": false,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/dev-harness/planning-draft-output",
  "allOf": [
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "backend"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "backend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "frontend"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "frontend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "architecture"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "architecture_artifact_update"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "backend_frontend"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "backend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "frontend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "backend_architecture"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "backend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "architecture_artifact_update"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "frontend_architecture"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "frontend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "architecture_artifact_update"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "implementation_route": {
            "const": "all"
          }
        },
        "required": [
          "implementation_route"
        ]
      },
      "then": {
        "properties": {
          "selected_implementation_steps": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "uniqueItems": true,
            "allOf": [
              {
                "contains": {
                  "const": "backend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "frontend_implementation"
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "const": "architecture_artifact_update"
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "enum": [
                "backend_implementation",
                "frontend_implementation",
                "architecture_artifact_update"
              ]
            }
          }
        }
      }
    }
  ]
}
