{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/dev-harness/schemas/worker-output",
  "title": "DevHarness Worker Or Approval Output",
  "type": "object",
  "minProperties": 1,
  "properties": {
    "outcome": { "type": "string" },
    "approval": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "https://openclaw.local/dev-harness/schemas/baton#/$defs/artifact" }
    },
    "results": {
      "type": "array",
      "items": { "$ref": "https://openclaw.local/dev-harness/schemas/baton#/$defs/result" }
    },
    "blocker": { "type": "object" }
  },
  "additionalProperties": false,
  "anyOf": [
    { "required": ["outcome"] },
    { "required": ["approval"] }
  ]
}
