{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/dev-harness/schemas/workflow",
  "title": "DevHarness Workflow Document",
  "type": "object",
  "required": ["workflow"],
  "properties": {
    "workflow": {
      "type": "object",
      "required": ["name", "version", "start", "done", "blocked", "steps"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "start": { "type": "string" },
        "done": { "type": "string" },
        "blocked": { "type": "string" },
        "steps": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/step" }
        }
      },
      "additionalProperties": true
    },
    "prompt_generation": { "type": "object" },
    "workflow_interpreter": { "type": "object" }
  },
  "additionalProperties": false,
  "$defs": {
    "step": {
      "description": "Canonical target workflow step shape.",
      "oneOf": [
        { "$ref": "#/$defs/workerStep" },
        { "$ref": "#/$defs/approvalStep" },
        { "$ref": "#/$defs/doneStep" }
      ]
    },
    "workerStep": {
      "type": "object",
      "required": ["name", "kind", "output"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "const": "worker" },
        "input": { "$ref": "#/$defs/workerInput" },
        "output": { "$ref": "#/$defs/output" },
        "next": { "$ref": "#/$defs/next" }
      },
      "additionalProperties": false
    },
    "approvalStep": {
      "type": "object",
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "const": "approval" },
        "input": { "$ref": "#/$defs/input" },
        "next": { "$ref": "#/$defs/next" }
      },
      "additionalProperties": false
    },
    "doneStep": {
      "type": "object",
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "const": "done" },
        "input": { "$ref": "#/$defs/input" }
      },
      "additionalProperties": false
    },
    "input": {
      "type": "object",
      "properties": {
        "template": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string" },
        "state": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "workerInput": {
      "type": "object",
      "properties": {
        "template": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string" },
        "state": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "role": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "next": {
      "description": "Next step target, or a light map from an output field value to a step target.",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["by", "map"],
          "properties": {
            "by": { "type": "string", "minLength": 1 },
            "map": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "output": {
      "type": "object",
      "required": ["schema"],
      "properties": {
        "schema": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
