{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/dev-harness/schemas/workflow",
  "title": "DevHarness Workflow Document",
  "type": "object",
  "required": ["workflow"],
  "properties": {
    "workflow": {
      "type": "object",
      "required": ["name", "version", "start", "done", "blocked", "steps"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "start": { "type": "string" },
        "done": { "type": "string" },
        "blocked": { "type": "string" },
        "steps": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/step" }
        }
      },
      "additionalProperties": true
    },
    "prompt_generation": { "type": "object" },
    "workflow_interpreter": { "type": "object" }
  },
  "additionalProperties": false,
  "$defs": {
    "step": {
      "description": "Canonical target workflow step shape.",
      "type": "object",
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["worker", "approval", "done"] },
        "input": { "$ref": "#/$defs/input" },
        "output": { "$ref": "#/$defs/output" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "worker" } },
            "required": ["kind"]
          },
          "then": true,
          "else": { "not": { "required": ["output"] } }
        }
      ]
    },
    "input": {
      "type": "object",
      "properties": {
        "template": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string" },
        "state": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "required": ["schema"],
      "properties": {
        "schema": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
