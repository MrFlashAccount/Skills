{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/workflow",
  "title": "Workflow Document",
  "type": "object",
  "required": ["workflow"],
  "properties": {
    "workflow": {
      "type": "object",
      "required": ["name", "version", "start", "done", "blocked", "steps"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "start": { "type": "string", "minLength": 1 },
        "done": { "type": "string", "minLength": 1 },
        "blocked": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/step" }
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "description": "Optional workflow-instance metadata ignored by the generic workflow interpreter. Use this for prompts, templates, or operational hints owned by a specific workflow instance.",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "step": {
      "description": "Canonical target workflow step shape.",
      "oneOf": [
        { "$ref": "#/$defs/workerStep" },
        { "$ref": "#/$defs/approvalStep" },
        { "$ref": "#/$defs/blockedStep" },
        { "$ref": "#/$defs/doneStep" }
      ]
    },
    "workerStep": {
      "type": "object",
      "required": ["name", "kind", "output", "next"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "const": "worker" },
        "input": { "$ref": "#/$defs/workerInput" },
        "output": { "$ref": "#/$defs/output" },
        "next": { "$ref": "#/$defs/next" }
      },
      "additionalProperties": false
    },
    "approvalStep": {
      "type": "object",
      "required": ["name", "kind", "next"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "const": "approval" },
        "input": { "$ref": "#/$defs/input" },
        "next": { "$ref": "#/$defs/next" }
      },
      "additionalProperties": false
    },
    "doneStep": {
      "type": "object",
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "const": "done" },
        "input": { "$ref": "#/$defs/input" }
      },
      "additionalProperties": false
    },
    "blockedStep": {
      "type": "object",
      "required": ["name", "kind"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": { "const": "blocked" },
        "input": { "$ref": "#/$defs/input" }
      },
      "additionalProperties": false
    },
    "input": {
      "type": "object",
      "properties": {
        "template": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string" },
        "state": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "workerInput": {
      "type": "object",
      "properties": {
        "template": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string" },
        "state": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "role": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "next": {
      "description": "Next step target, or a light map from an output field value to a step target. Map entries may use an edge policy object for bounded loop retries; runtime must persist per-edge/target attempt counters in baton/run state.",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["by", "map"],
          "properties": {
            "by": { "type": "string", "minLength": 1 },
            "map": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": { "$ref": "#/$defs/nextTarget" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "nextTarget": {
      "description": "Simple step target string, or an edge-specific bounded retry policy. onLimit is scoped to this map entry only.",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/nextTargetPolicy" }
      ]
    },
    "nextTargetPolicy": {
      "type": "object",
      "required": ["target", "maxAttempts", "onLimit"],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "onLimit": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "required": ["schema"],
      "properties": {
        "schema": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
