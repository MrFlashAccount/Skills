{
  "name": "fixture-approval-first-fanout",
  "version": 1,
  "start": "intake_approval",
  "done": "done",
  "steps": {
    "intake_approval": {
      "name": "Intake Approval",
      "kind": "approval",
      "input": {
        "prompt": "Accept the startup request before worker execution."
      },
      "next": "prepare"
    },
    "prepare": {
      "name": "Prepare",
      "kind": "worker",
      "input": {
        "prompt": "Prepare approved startup request."
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-ready.schema.json"
      },
      "next": [
        "branch_a",
        "branch_b"
      ]
    },
    "branch_a": {
      "name": "Branch A",
      "kind": "worker",
      "input": {
        "prompt": [
          "Do branch A.",
          "",
          "Prepare result:",
          "${{ input.prepare.results }}"
        ]
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-ready.schema.json"
      },
      "next": "join"
    },
    "branch_b": {
      "name": "Branch B",
      "kind": "worker",
      "input": {
        "prompt": [
          "Do branch B.",
          "",
          "Prepare result:",
          "${{ input.prepare.results }}"
        ]
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-ready.schema.json"
      },
      "next": "join"
    },
    "join": {
      "name": "Join",
      "kind": "worker",
      "input": {
        "prompt": [
          "Join branch results.",
          "",
          "Branch A result:",
          "${{ input.branch_a.results }}",
          "",
          "Branch B result:",
          "${{ input.branch_b.results }}"
        ]
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-ready.schema.json"
      },
      "next": "final_approval"
    },
    "final_approval": {
      "name": "Final Approval",
      "kind": "approval",
      "input": {
        "prompt": [
          "Approve final result.",
          "",
          "Join result:",
          "${{ input.join.results }}"
        ]
      },
      "next": {
        "match": "${{ output.approval }}",
        "cases": {
          "approved": "done"
        }
      }
    },
    "done": {
      "name": "Done",
      "kind": "done",
      "input": {
        "prompt": "Finished."
      }
    }
  }
}
