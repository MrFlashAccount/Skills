{
  "name": "fixture-long-revision",
  "version": 1,
  "start": "plan",
  "done": "done",
  "blocked": "blocked",
  "steps": {
    "plan": {
      "name": "Plan",
      "kind": "worker",
      "input": {
        "prompt": "Plan the work."
      },
      "output": {
        "template": "output.md"
      },
      "next": "approval_gate"
    },
    "approval_gate": {
      "name": "Approval Gate",
      "kind": "approval",
      "input": {
        "state": [
          "plan"
        ],
        "prompt": [
          "Approve the plan.",
          "",
          "Plan result:",
          "${{ input.plan.results }}"
        ]
      },
      "next": {
        "match": "${{ output.approval }}",
        "cases": {
          "approved": "implement",
          "rejected": "plan",
          "blocked": "blocked"
        }
      }
    },
    "implement": {
      "name": "Implement",
      "kind": "worker",
      "input": {
        "state": [
          "plan",
          "approval_gate",
          "review"
        ],
        "prompt": [
          "Implement the approved plan.",
          "",
          "Plan result:",
          "${{ input.plan.results }}",
          "",
          "Approval decision:",
          "${{ input.approval_gate }}",
          "",
          "Review feedback to address:",
          "${{ input.review.results | default: \"No review feedback yet.\" }}"
        ]
      },
      "output": {
        "template": "output.md"
      },
      "next": "review"
    },
    "review": {
      "name": "Review",
      "kind": "worker",
      "input": {
        "state": [
          "implement"
        ],
        "prompt": [
          "Review implementation.",
          "",
          "Implementation result:",
          "${{ input.implement.results }}"
        ]
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-review.schema.json"
      },
      "next": {
        "match": "${{ output.outcome }}",
        "cases": {
          "ready": "done",
          "retry": "implement",
          "blocked": "blocked"
        }
      }
    },
    "done": {
      "name": "Done",
      "kind": "done",
      "input": {
        "prompt": "Finished."
      }
    },
    "blocked": {
      "name": "Blocked",
      "kind": "blocked",
      "input": {
        "prompt": "Blocked."
      }
    }
  }
}
