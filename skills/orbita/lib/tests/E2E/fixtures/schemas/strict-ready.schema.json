{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["outcome", "ticket", "results"],
  "properties": {
    "outcome": { "const": "ready" },
    "ticket": { "type": "string", "minLength": 3 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "summary"],
        "properties": {
          "type": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/artifact" }
    }
  },
  "additionalProperties": true
}
