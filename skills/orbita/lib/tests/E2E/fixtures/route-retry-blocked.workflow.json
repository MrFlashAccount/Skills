{
  "name": "fixture-route-retry-blocked",
  "version": 1,
  "start": "triage",
  "done": "done",
  "steps": {
    "triage": {
      "name": "Triage",
      "kind": "worker",
      "input": {
        "prompt": "Classify the request."
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-review.schema.json"
      },
      "next": {
        "match": "${{ output.outcome }}",
        "cases": {
          "ready": "resolve",
          "retry": "triage"
        }
      }
    },
    "resolve": {
      "name": "Resolve",
      "kind": "worker",
      "input": {
        "prompt": [
          "Resolve ready request.",
          "",
          "Triage result:",
          "${{ input.triage.results }}"
        ]
      },
      "output": {
        "template": "output.md"
      },
      "next": "done"
    },
    "done": {
      "name": "Done",
      "kind": "done",
      "input": {
        "prompt": "Finished."
      }
    }
  }
}
