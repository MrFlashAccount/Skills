{
  "name": "fixture-schema-retry",
  "version": 1,
  "start": "schema_worker",
  "done": "done",
  "steps": {
    "schema_worker": {
      "name": "Schema Worker",
      "kind": "worker",
      "input": {
        "prompt": "Return strict ready ticket output."
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/strict-ready.schema.json"
      },
      "next": "done"
    },
    "done": {
      "name": "Done",
      "kind": "done",
      "input": {
        "prompt": "Finished."
      }
    }
  }
}
