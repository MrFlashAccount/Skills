{
  "name": "fixture-parallel-mixed",
  "version": 1,
  "start": "prepare",
  "done": "done",
  "blocked": "blocked",
  "steps": {
    "prepare": {
      "name": "Prepare",
      "kind": "worker",
      "input": {
        "prompt": "Prepare branch inputs."
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-ready.schema.json"
      },
      "next": [
        "lint",
        {
          "match": "${{ output.outcome }}",
          "cases": {
            "ready": "build"
          }
        }
      ]
    },
    "lint": {
      "name": "Lint",
      "kind": "worker",
      "input": {
        "prompt": [
          "Run lint branch.",
          "",
          "Prepare result:",
          "${{ input.prepare.results }}"
        ]
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-ready.schema.json"
      },
      "next": "join"
    },
    "build": {
      "name": "Build",
      "kind": "worker",
      "input": {
        "prompt": [
          "Run build branch.",
          "",
          "Prepare result:",
          "${{ input.prepare.results }}"
        ]
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-ready.schema.json"
      },
      "next": "join"
    },
    "join": {
      "name": "Join",
      "kind": "worker",
      "input": {
        "prompt": [
          "Synthesize branch outputs.",
          "",
          "Lint result:",
          "${{ input.lint.results }}",
          "",
          "Build result:",
          "${{ input.build.results }}"
        ]
      },
      "output": {
        "template": "output.md",
        "schema": "schemas/routing-ready.schema.json"
      },
      "next": "done"
    },
    "done": {
      "name": "Done",
      "kind": "done",
      "input": {
        "prompt": "Finished."
      }
    },
    "blocked": {
      "name": "Blocked",
      "kind": "blocked",
      "input": {
        "prompt": "Blocked."
      }
    }
  }
}
