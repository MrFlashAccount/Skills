{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/internal/cli-args/workflow-interpreter",
  "title": "Workflow Interpreter CLI Arguments",
  "description": "Internal positional argv contract for ./lib/entrypoints/cli/workflow-interpreter.mjs after node:util parseArgs normalization.",
  "oneOf": [
    { "$ref": "#/$defs/inspectMode" },
    { "$ref": "#/$defs/renderMode" },
    { "$ref": "#/$defs/applyMode" }
  ],
  "$defs": {
    "pathArg": { "type": "string", "minLength": 1 },
    "inspectMode": {
      "type": "array",
      "prefixItems": [
        { "const": "inspect" },
        { "$ref": "#/$defs/pathArg" },
        { "$ref": "#/$defs/pathArg" }
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "renderMode": {
      "type": "array",
      "prefixItems": [
        { "const": "render" },
        { "$ref": "#/$defs/pathArg" },
        { "$ref": "#/$defs/pathArg" }
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "applyMode": {
      "type": "array",
      "prefixItems": [
        { "const": "apply" },
        { "$ref": "#/$defs/pathArg" },
        { "$ref": "#/$defs/pathArg" },
        { "$ref": "#/$defs/pathArg" }
      ],
      "minItems": 4,
      "maxItems": 4
    }

  }
}
