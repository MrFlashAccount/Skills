{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/workflow-interpreter-response",
  "title": "Workflow Interpreter Response",
  "type": "object",
  "required": ["baton", "steps"],
  "properties": {
    "baton": { "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/executableStep" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "executableStep": {
      "type": "object",
      "required": ["id", "action", "step"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "action": { "enum": ["run_worker", "wait_for_approval", "stop_done", "stop_blocked"] },
        "step": { "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/workflow#/$defs/step" },
        "compiledPrompt": { "$ref": "#/$defs/compiledPrompt" },
        "approvalPrompt": { "$ref": "#/$defs/approvalPrompt" }
      },
      "additionalProperties": false
    },
    "compiledPrompt": {
      "type": "object",
      "required": ["prompt"],
      "properties": {
        "prompt": { "type": "string" },
        "metadata": {
          "type": "object",
          "properties": {
            "inputTemplate": { "type": "string", "minLength": 1 },
            "outputTemplate": { "type": "string", "minLength": 1 },
            "outputSchema": { "type": "string", "minLength": 1 },
            "roleMaterial": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "projectedStateKeys": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "projectedArtifacts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["label", "path"],
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "label": { "type": "string", "minLength": 1 },
                  "path": { "type": "string", "minLength": 1 },
                  "sourceStepId": { "type": "string", "minLength": 1 },
                  "contentType": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              }
            },
            "projectedSummaries": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["sourceStepId", "kind", "summary"],
                "properties": {
                  "sourceStepId": { "type": "string", "minLength": 1 },
                  "kind": { "enum": ["approval", "artifact", "result"] },
                  "summary": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "diagnostics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["severity", "code", "message"],
            "properties": {
              "severity": { "enum": ["info", "warning", "error"] },
              "code": { "type": "string", "minLength": 1 },
              "message": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "approvalPrompt": {
      "type": "object",
      "properties": {
        "promptLayer": { "type": "string" },
        "workflowInstruction": { "type": "string" },
        "state": {
          "type": "object",
          "additionalProperties": true
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "path"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "sourceStepId": { "type": "string", "minLength": 1 },
              "contentType": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "summaries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sourceStepId", "kind", "summary"],
            "properties": {
              "sourceStepId": { "type": "string", "minLength": 1 },
              "kind": { "enum": ["approval", "artifact", "result"] },
              "summary": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
