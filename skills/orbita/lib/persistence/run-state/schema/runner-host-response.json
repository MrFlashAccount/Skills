{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrFlashAccount/Skills/schemas/workflow/runner-host-response",
  "title": "Workflow Runner Host Response",
  "type": "object",
  "required": ["status", "orchestratorInstruction", "baton"],
  "properties": {
    "status": { "enum": ["needs_host_actions", "done"] },
    "orchestratorInstruction": { "type": "string", "minLength": 1 },
    "orchestratorDebugCommand": { "type": "string", "minLength": 1 },
    "baton": { "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton" },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "stepId", "action"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "stepId": { "type": "string", "minLength": 1 },
          "action": { "enum": ["run_worker", "wait_for_approval"] },
          "loadInstructionsCommand": { "type": "string", "minLength": 1 },
          "preferredAgentId": {
            "description": "Advisory opaque worker id previously bound for this step, or null when no binding exists.",
            "type": ["string", "null"],
            "minLength": 1
          },
          "bindAgentCommand": {
            "description": "Public runner command for binding the actual selected worker id to this step. Hosts replace only the literal <agent-id> placeholder.",
            "type": "string",
            "minLength": 1
          },
          "loadFollowupInstructionsCommand": {
            "description": "Instruction-loader command variant for a host-restored preferred worker. Uses the same validating write-output protocol as loadInstructionsCommand.",
            "type": "string",
            "minLength": 1
          },
          "recoverableBlocker": {
            "description": "Bounded public blocker details for a recoverable implementation-worker pause. Hosts should first try the same-worker follow-up path when preferredAgentId can be restored, and fall back to loadInstructionsCommand for a fresh worker; generated fresh-worker instructions include this recovery context.",
            "$ref": "https://github.com/MrFlashAccount/Skills/schemas/workflow/baton#/$defs/recoverableWorkerBlocker"
          },
          "outputSchema": { "type": "string", "minLength": 1 },
          "resolvedOutputSchema": {
            "type": "object",
            "properties": {
              "ref": { "type": "string", "minLength": 1 },
              "schema": { "type": "object" }
            },
            "required": ["ref", "schema"],
            "additionalProperties": false
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": { "action": { "const": "run_worker" } },
              "required": ["action"]
            },
            "then": {
              "required": [
                "loadInstructionsCommand",
                "preferredAgentId",
                "bindAgentCommand",
                "loadFollowupInstructionsCommand"
              ]
            }
          },
          {
            "if": {
              "properties": { "action": { "const": "wait_for_approval" } },
              "required": ["action"]
            },
            "then": {
              "not": {
                "anyOf": [
                  { "required": ["preferredAgentId"] },
                  { "required": ["bindAgentCommand"] },
                  { "required": ["loadFollowupInstructionsCommand"] },
                  { "required": ["recoverableBlocker"] }
                ]
              }
            }
          }
        ]
      }
    },
    "runId": { "type": "string", "minLength": 1 },
    "initialized": { "type": "boolean" },
    "resumed": { "type": "boolean" }
  },
  "additionalProperties": false
}
